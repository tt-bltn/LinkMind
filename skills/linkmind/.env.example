# ============================================================
# LinkMind 敏感凭据配置
# 复制本文件为 .env 并填入真实值：cp .env.example .env
# 所有凭据均为可选，不配置不影响基础抓取功能。
# ============================================================

# --- 平台 Cookie（可选）---
# 仅在需要获取登录后才可见的内容时才需要配置，公开内容无需 Cookie。
# 获取方式：浏览器登录平台 → F12 → Application → Cookies → 复制为分号分隔字符串
LINKMIND_WEIBO_COOKIE=
LINKMIND_XHS_COOKIE=
# 微信公众号 Cookie（可选，用于获取阅读/点赞/在看统计数据）
# 获取方式：微信内打开文章 → 复制链接到浏览器 → F12 → Application → Cookies → mp.weixin.qq.com
LINKMIND_WXMP_COOKIE=

# --- 小宇宙 Token（可选，用于获取平台字幕）---
# 配置后优先使用平台字幕（质量更好），无需 ASR 转写，可节省 ASR 费用。
# 未配置时自动降级为 ASR 转写（需配置下方讯飞或 OpenAI）。
# 获取方式：Charles/mitmproxy 抓包小宇宙 App → 找任意 API 请求 → 复制 x-jike-access-token 请求头值（JWT）
LINKMIND_XIAOYUZHOU_TOKEN=

# --- 科大讯飞 ASR（可选，用于视频转写）---
# 获取方式：xfyun.cn → 注册 → 创建应用 → 开通「录音文件转写标准版」服务
# 控制台：语音识别 → 录音文件转写标准版 → 查看 APPID 和 SecretKey
LINKMIND_IFLYTEK_APP_ID=
LINKMIND_IFLYTEK_SECRET_KEY=

# --- OpenAI Whisper ASR（可选，讯飞的备选方案）---
# 获取方式：platform.openai.com/api-keys
LINKMIND_OPENAI_API_KEY=
LINKMIND_OPENAI_BASE_URL=https://api.openai.com/v1
# 转写模型名称，默认 whisper-1；使用兼容接口时可改为对应模型名
LINKMIND_OPENAI_MODEL=whisper-1
