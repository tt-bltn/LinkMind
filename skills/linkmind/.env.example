# LinkMind 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 微博 Cookie（可选，用于获取需登录的内容）
# 获取方式：登录 weibo.com → F12 → Application → Cookies → 复制 SUB、SUBP 等
LINKMIND_WEIBO_COOKIE=

# 小红书 Cookie（可选，用于获取需登录的内容）
# 获取方式：登录 xiaohongshu.com → F12 → Application → Cookies → 复制 a1、web_session 等
LINKMIND_XHS_COOKIE=

# 微信公众号 Cookie（可选，用于获取阅读/点赞/在看统计数据）
# 获取方式：微信内打开文章 → 复制链接到浏览器 → F12 → Application → Cookies → mp.weixin.qq.com
LINKMIND_WXMP_COOKIE=

# 科大讯飞 ASR（可选，用于视频转写）
# 获取方式：xfyun.cn → 创建应用 → 开通「语音转写」服务
LINKMIND_IFLYTEK_APP_ID=
LINKMIND_IFLYTEK_API_KEY=
LINKMIND_IFLYTEK_API_SECRET=

# OpenAI Whisper ASR（可选，讯飞的备选方案）
LINKMIND_OPENAI_API_KEY=
